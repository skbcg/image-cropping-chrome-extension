{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "types": ["chrome", "vite/client"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "vite.background.config.ts", "vite.content.config.ts", "eslint.config.js"]
}
